generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum NewsStatus {
  DRAFT
  PUBLISHED
}

enum AdminAuditAction {
  PROMOTE
  DEMOTE
  BLOCK
  UNBLOCK
  REMOVE
}

enum DugoutMediaType {
  IMAGE
  GIF
}

enum DugoutNotificationEntityType {
  POST_LIKE
  COMMENT
}

model NewsPost {
  id          String     @id @default(cuid())
  title       String
  slug        String     @unique
  excerpt     String?
  content     String
  imageUrl    String?
  author      String?
  featured    Boolean    @default(false)
  rotatorEnabled Boolean @default(false)
  status      NewsStatus @default(DRAFT)
  publishedAt DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([status, publishedAt])
  @@index([slug])
}

model AdminUser {
  id           String          @id @default(cuid())
  email        String          @unique
  name         String?
  firstName    String?
  lastName     String?
  passwordHash String?
  avatarUrl    String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  sessions     AdminSession[]
  auditLogs    AdminAuditLog[] @relation("AdminActorLogs")
}

model RegisteredUser {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  firstName    String?
  lastName     String?
  isCoach      Boolean  @default(false)
  isBlocked    Boolean  @default(false)
  googleSub    String?  @unique
  passwordHash String?
  avatarUrl    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  auditLogs    AdminAuditLog[]
  sessions     CoachSession[]
  dugoutPosts  DugoutPost[]
  dugoutComments DugoutComment[]
  dugoutLikes  DugoutPostLike[]
  dugoutNotificationCursor DugoutNotificationCursor?
  dugoutNotificationReads DugoutNotificationRead[]
}

model CoachSession {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  userId    String
  user      RegisteredUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model DugoutPost {
  id        String          @id @default(cuid())
  content   String
  mediaUrl  String?
  mediaType DugoutMediaType?
  threadId  String?
  threadOrder Int?
  isPinned  Boolean         @default(false)
  pinnedAt  DateTime?
  authorId  String
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  author RegisteredUser   @relation(fields: [authorId], references: [id], onDelete: Cascade)
  comments DugoutComment[]
  likes  DugoutPostLike[]

  @@index([createdAt])
  @@index([authorId])
  @@index([threadId, threadOrder])
  @@index([isPinned, pinnedAt])
}

model DugoutComment {
  id        String   @id @default(cuid())
  content   String
  postId    String
  authorId  String
  parentId  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  post    DugoutPost       @relation(fields: [postId], references: [id], onDelete: Cascade)
  author  RegisteredUser   @relation(fields: [authorId], references: [id], onDelete: Cascade)
  parent  DugoutComment?   @relation("DugoutCommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies DugoutComment[]  @relation("DugoutCommentReplies")
  notificationReads DugoutNotificationRead[] @relation("NotificationReadComment")

  @@index([postId, createdAt])
  @@index([authorId, createdAt])
  @@index([parentId])
}

model DugoutPostLike {
  id        String         @id @default(cuid())
  postId    String
  userId    String
  reaction  String         @default("👍")
  createdAt DateTime       @default(now())

  post DugoutPost      @relation(fields: [postId], references: [id], onDelete: Cascade)
  user RegisteredUser  @relation(fields: [userId], references: [id], onDelete: Cascade)
  notificationReads DugoutNotificationRead[] @relation("NotificationReadLike")

  @@unique([postId, userId])
  @@index([postId])
  @@index([userId])
}

model DugoutNotificationCursor {
  id         String   @id @default(cuid())
  userId     String   @unique
  lastSeenAt DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user RegisteredUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([lastSeenAt])
}

model DugoutNotificationRead {
  id         String                        @id @default(cuid())
  userId     String
  entityType DugoutNotificationEntityType
  postLikeId String?
  commentId  String?
  readAt     DateTime                      @default(now())

  user     RegisteredUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  postLike DugoutPostLike? @relation("NotificationReadLike", fields: [postLikeId], references: [id], onDelete: Cascade)
  comment  DugoutComment?  @relation("NotificationReadComment", fields: [commentId], references: [id], onDelete: Cascade)

  @@unique([userId, postLikeId])
  @@unique([userId, commentId])
  @@index([userId, readAt])
  @@index([entityType, readAt])
}

model AdminSession {
  id        String    @id @default(cuid())
  tokenHash String    @unique
  expiresAt DateTime
  createdAt DateTime  @default(now())
  userId    String
  user      AdminUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model AdminAuditLog {
  id                     String            @id @default(cuid())
  action                 AdminAuditAction
  actorAdminId           String?
  actorEmail             String
  targetAdminId          String?
  targetRegisteredUserId String?
  targetEmail            String
  targetName             String?
  sourcePath             String?
  requestIp              String?
  createdAt              DateTime          @default(now())

  actorAdmin            AdminUser?       @relation("AdminActorLogs", fields: [actorAdminId], references: [id], onDelete: SetNull)
  targetRegisteredUser RegisteredUser? @relation(fields: [targetRegisteredUserId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([action, createdAt])
}
